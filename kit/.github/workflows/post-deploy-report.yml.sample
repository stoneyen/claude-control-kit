# GitHub Actions (self-hosted runner, ADR-059) — Release report (ADR-077).
#
# One HTML summary page per deployed commit. Chained off the SAME signal that
# authorizes a deploy (ADR-065): `checks` COMPLETING `success` on main. That is
# the moment a commit is cleared to build an image + roll out via Flux, so it is
# the deterministic "this will deploy" event (Flux rollout itself has no
# CI-observable completion). Generates deploy/reports/<sha>.html + index and
# commits it back to main with [skip ci] so the push does NOT re-trigger checks/
# image builds (loop broken — see ADR-077 Consequences).
name: post-deploy-report
on:
  workflow_run:
    workflows: ["checks"]
    types: [completed]
    branches: [main]
  workflow_dispatch:
    inputs:
      sha:
        description: "commit SHA to (re)generate a report for"
        required: false
permissions:
  contents: write   # push the report commit back to main
  actions: read     # read this SHA's workflow-run results (the report's CI data);
                    # NOTE: naming any permission defaults all others to `none`,
                    # so actions:read MUST be listed or the API returns 403.
concurrency:
  group: post-deploy-report
  cancel-in-progress: false
jobs:
  report:
    runs-on: [self-hosted, Linux, ARM64]
    # Run in a container that ships python3 + git + curl (the bare self-hosted
    # runner has no python3). buildpack-deps-based python:3.13-bookworm bundles
    # curl + git, so the generator's curl fallback to the GitHub API works with
    # no `gh` install.
    container:
      image: python:3.13-bookworm
    # github.com only (Forgejo also reads .github/workflows); manual dispatch
    # always allowed; automated runs ONLY when the checks gate went green.
    if: >
      github.server_url == 'https://github.com' &&
      (github.event_name == 'workflow_dispatch' ||
       github.event.workflow_run.conclusion == 'success')
    env:
      GH_TOKEN: ${{ github.token }}
      TRIGGER_SHA: ${{ github.event.workflow_run.head_sha }}
      INPUT_SHA: ${{ github.event.inputs.sha }}
    steps:
      - name: generate + commit release report
        shell: bash   # the container defaults to `sh`; the script uses ${SHA:0:8}
        run: |
          set -eu
          git config --global --add safe.directory '*'
          rm -rf src   # the runner reuses the workdir between runs
          git clone "https://x-access-token:${GH_TOKEN}@github.com/<OWNER>/<REPO>.git" src
          cd src
          SHA="${INPUT_SHA:-${TRIGGER_SHA:-$GITHUB_SHA}}"
          git config user.name  "mywb-release-bot"
          git config user.email "release-bot@mywb.local"

          # Stable timestamp keyed on the reported commit so re-runs for the same
          # SHA produce byte-identical output → the "nothing to commit" guard
          # actually short-circuits (idempotent; no timestamp-churn re-commit).
          STAMP="$(git show -s --format=%cI "$SHA")"

          # Surface the report link in this run's Summary tab (the deploy's final
          # summary in the Actions UI). Called on both success paths below.
          summary() {
            local url="https://github.com/<OWNER>/<REPO>/blob/main/deploy/reports/${SHA}.html"
            {
              echo "## 📄 Release report — \`${SHA:0:8}\`"
              echo ""
              echo "- **Report:** [deploy/reports/${SHA:0:8}.html](${url})"
              echo "- **All reports:** [index](https://github.com/<OWNER>/<REPO>/blob/main/deploy/reports/index.html)"
              echo ""
              echo "_mywb is private → GitHub shows the HTML source; open the file locally for the rendered page (ADR-077)._"
            } >> "${GITHUB_STEP_SUMMARY:-/dev/null}"
          }

          # Generate + push, retrying against concurrent bot/Flux pushes. Each
          # attempt starts from a CLEAN origin/main tip (reset --hard, no dirty
          # tree) then generates once — the report only needs --sha, not the tree
          # parked at the code commit. This fixes the "checkout -B main aborts
          # when main is ahead of SHA" abort and needs no rebase (deterministic
          # content → no conflicts). [skip ci] keeps checks from re-firing.
          for i in 1 2 3; do
            git fetch origin main
            git checkout -B main origin/main
            git reset --hard origin/main
            # --require-actions: fail loud if the Actions API is unreachable, so
            # a degraded (gh-less) CI run can't silently ship an inventory-only page.
            python3 deploy/scripts/gen_release_report.py generate \
              --sha "$SHA" --repo <OWNER>/<REPO> --generated-at "$STAMP" --require-actions
            git add deploy/reports
            if git diff --cached --quiet; then
              echo "release report unchanged — nothing to commit"; summary; exit 0
            fi
            git commit -m "chore(release-report): summary for ${SHA:0:8} [skip ci]"
            if git push origin main; then echo "pushed"; summary; exit 0; fi
            echo "push rejected (attempt $i) — retrying from fresh main"
          done
          echo "giving up after 3 attempts"; exit 1
