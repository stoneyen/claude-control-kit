# python-ddd profile config. Copy to `.dev/gates/profile.env` and edit.
# Sourced by every python-ddd gate wrapper.
CCK_PKG=mywb                 # your package name under src/<PKG>/
CCK_PY_ROOT=backend          # dir holding scripts/ + src/ + pyproject (use "." if repo root)
CCK_PY="uv run python"       # how to run python in this project (e.g. "python3", "poetry run python")
CCK_RUFF="uv run ruff"       # linter invocation
CCK_MYPY="uv run mypy"       # type checker invocation
